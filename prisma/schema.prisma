generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Site {
  id          String   @id @default(cuid())
  name        String
  url         String   @default("")
  platform    String   @default("webflow")
  webflowId   String?  @unique @map("webflow_id")
  cookiebotId String?  @map("cookiebot_id")
  gtmId       String?  @map("gtm_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  audits Audit[]

  @@map("sites")
}

model Audit {
  id           String   @id @default(cuid())
  siteId       String   @map("site_id")
  status       String   @default("in_progress")
  notes        String   @default("")
  auditorName  String?  @map("auditor_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  site    Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  results CheckResult[]
  scans   ScanRun[]
  reports Report[]

  @@map("audits")
}

model Report {
  id               String   @id @default(cuid())
  auditId          String   @map("audit_id")
  version          Int      @default(1)
  executiveSummary  String   @default("") @map("executive_summary")
  conclusion       String   @default("") @map("conclusion")
  snapshotHtml     String   @map("snapshot_html")
  statsOk          Int      @default(0) @map("stats_ok")
  statsIssues      Int      @default(0) @map("stats_issues")
  statsNa          Int      @default(0) @map("stats_na")
  statsNotChecked  Int      @default(0) @map("stats_not_checked")
  createdAt        DateTime @default(now()) @map("created_at")

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model CheckResult {
  id          String   @id @default(cuid())
  auditId     String   @map("audit_id")
  checkKey    String   @map("check_key")
  status      String   @default("not_checked")
  notes       String   @default("")
  source      String   @default("manual") @map("source")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, checkKey])
  @@map("check_results")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model ScanRun {
  id          String   @id @default(cuid())
  auditId     String   @map("audit_id")
  scanType    String   @map("scan_type")
  url         String
  status      String   @default("running")
  findings    String   @default("[]")
  error       String?
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@map("scan_runs")
}
