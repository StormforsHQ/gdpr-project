# ============================================================
# Environment Variables
# ============================================================
#
# Production values are set in Coolify (app > Environment Variables).
# The database is PostgreSQL hosted on Hetzner via Coolify - there
# is no local database. Because of this, running a local dev server
# is not useful for testing real data flows. All development and
# testing is done against the deployed instance.
#
# These values are left empty intentionally. If you want to run the
# UI locally (with non-persistent/dummy data), you can fill them in.
#
# ============================================================

# PostgreSQL connection string
# Production: Hetzner VM managed by Coolify
DATABASE_URL=

# OpenRouter API key for AI-powered checks
# Production: already configured in Coolify
OPENROUTER_API_KEY=

# Webflow API token - needed for auto-fix of site header/footer scripts
# Add to Coolify when ready to use fix automation
WEBFLOW_API_TOKEN=

# Google Tag Manager API token - needed for auto-fix of GTM tags/triggers
# Add to Coolify when ready to use fix automation
GTM_API_TOKEN=
